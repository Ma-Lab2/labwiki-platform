:80 {
    @allowed_host host {$PRIVATE_HOST}
    @noncanonical_host not host {$PRIVATE_HOST}

    redir @noncanonical_host http://{$PRIVATE_HOST}:8443{uri} 308

    encode zstd gzip
    handle_path /tools/assistant/api/* {
        reverse_proxy assistant_api:8000
    }
    handle_path /tools/tps/* {
        reverse_proxy tps_web:8000
    }
    handle_path /tools/rcf/* {
        reverse_proxy rcf_frontend:80
    }
    root * /var/www/html
    php_fastcgi mw_private:9000
    file_server
}
