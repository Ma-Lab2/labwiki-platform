TZ=Asia/Shanghai
MW_LANG=zh-cn

PUBLIC_HOST=lab.example.com
PRIVATE_HOST=wiki.lab.internal
CADDY_EMAIL=admin@example.com

PUBLIC_SITE_NAME=课题组公开档案
PRIVATE_SITE_NAME=实验运行台账

PUBLIC_ADMIN_USER=admin
PRIVATE_ADMIN_USER=admin
ASSISTANT_DB_USER=labassistant
ASSISTANT_DB_NAME=labassistant
ASSISTANT_DRAFT_PREFIX=知识助手草稿
ASSISTANT_ENABLE_WEB_SEARCH=true
ASSISTANT_LLM_BACKEND=openai
ASSISTANT_SIMADVISOR_EXECUTOR=/mnt/c/Songtan/Gewu/skills/L2-methodology/sim-advisor/executor.py
ASSISTANT_SIMADVISOR_DEFAULT_MODEL=claude-sonnet-4-5-20250929-thinking
ASSISTANT_SIMADVISOR_FALLBACK_MODEL=gemini-3.1-pro-preview-all
ASSISTANT_SIMADVISOR_REVIEW_MODEL=claude-opus-4-6
ASSISTANT_SIMADVISOR_TIMEOUT=180

# Optional OpenAI-compatible provider for synthesis and embeddings.
ASSISTANT_OPENAI_BASE_URL=
ASSISTANT_OPENAI_API_KEY=
ASSISTANT_OPENAI_MODEL=gpt-4.1-mini
ASSISTANT_EMBEDDING_MODEL=

# TPS raw image root mounted into /tools/tps/.
# Example: /mnt/c/path/to/lab-tps-images
TPS_IMAGE_DIR=./tools-data/tps/images
