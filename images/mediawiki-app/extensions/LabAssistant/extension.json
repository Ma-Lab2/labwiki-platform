{
  "name": "LabAssistant",
  "version": "0.1.8",
  "author": [
    "OpenAI Codex"
  ],
  "url": "https://github.com/Ma-Lab2/labwiki-platform",
  "descriptionmsg": "labassistant-desc",
  "license-name": "MIT",
  "AutoloadNamespaces": {
    "MediaWiki\\Extension\\LabAssistant\\": "includes/"
  },
  "MessagesDirs": {
    "LabAssistant": [
      "i18n"
    ]
  },
  "ExtensionMessagesFiles": {
    "LabAssistantAliases": "LabAssistant.alias.php"
  },
  "SpecialPages": {
    "LabAssistant": "MediaWiki\\Extension\\LabAssistant\\SpecialLabAssistant",
    "LabAssistantAdmin": "MediaWiki\\Extension\\LabAssistant\\SpecialLabAssistantAdmin"
  },
  "ResourceModules": {
    "ext.labassistant.shell": {
      "scripts": [
        "modules/ext.labassistant.asset-version.js",
        "modules/ext.labassistant.editor-utils.js",
        "modules/ext.labassistant.editor-upload-utils.js",
        "modules/ext.labassistant.attachment-utils.js",
        "modules/ext.labassistant.pdf-reader-utils.js",
        "modules/ext.labassistant.pdf-ingest-utils.js",
        "modules/ext.labassistant.session-export-utils.js",
        "modules/ext.labassistant.shell-utils.js",
        "modules/ext.labassistant.shell.js"
      ],
      "styles": [
        "modules/ext.labassistant.ui.css"
      ],
      "dependencies": [
        "mediawiki.util",
        "mediawiki.api"
      ],
      "targets": [
        "desktop",
        "mobile"
      ]
    },
    "ext.labassistant.ui": {
      "scripts": [
        "modules/vendor/highlight/highlight.min.js",
        "modules/vendor/marked.umd.js",
        "modules/vendor/purify.min.js",
        "modules/ext.labassistant.asset-version.js",
        "modules/ext.labassistant.editor-utils.js",
        "modules/ext.labassistant.editor-upload-utils.js",
        "modules/ext.labassistant.attachment-utils.js",
        "modules/ext.labassistant.pdf-reader-utils.js",
        "modules/ext.labassistant.pdf-ingest-utils.js",
        "modules/ext.labassistant.session-export-utils.js",
        "modules/ext.labassistant.shell-utils.js",
        "modules/ext.labassistant.ui.js"
      ],
      "styles": [
        "modules/vendor/highlight/github.min.css",
        "modules/ext.labassistant.ui.css"
      ],
      "dependencies": [
        "mediawiki.util"
      ],
      "targets": [
        "desktop",
        "mobile"
      ]
    },
    "ext.labassistant.admin": {
      "scripts": [
        "modules/ext.labassistant.admin.js"
      ],
      "styles": [
        "modules/ext.labassistant.ui.css"
      ],
      "targets": [
        "desktop",
        "mobile"
      ]
    }
  },
  "ResourceFileModulePaths": {
    "localBasePath": "",
    "remoteExtPath": "LabAssistant"
  },
  "Hooks": {
    "BeforePageDisplay": "MediaWiki\\Extension\\LabAssistant\\Hooks::onBeforePageDisplay"
  },
  "config": {
    "LabAssistantApiBase": {
      "value": "/tools/assistant/api"
    },
    "LabAssistantDraftPrefix": {
      "value": "知识助手草稿"
    },
    "LabAssistantModes": {
      "value": [
        "qa",
        "compare",
        "draft"
      ]
    },
    "LabAssistantDetailLevels": {
      "value": [
        "intro",
        "intermediate",
        "research"
      ]
    },
    "LabAssistantAssetEpoch": {
      "value": "2026-03-26-pdf-control-formalize-1"
    }
  },
  "manifest_version": 2
}
