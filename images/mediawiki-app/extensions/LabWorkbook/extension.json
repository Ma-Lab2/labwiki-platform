{
  "name": "LabWorkbook",
  "version": "0.1.0",
  "author": [
    "OpenAI Codex"
  ],
  "url": "https://github.com/Ma-Lab2/labwiki-platform",
  "descriptionmsg": "labworkbook-desc",
  "license-name": "MIT",
  "AutoloadNamespaces": {
    "MediaWiki\\Extension\\LabWorkbook\\": "includes/"
